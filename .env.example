# Copy to .env and fill in. Never commit .env.

# Model provider keys (LiteLLM reads these). Set the one(s) you actually use.
# Free Gemini key (covers the default Flash models): https://aistudio.google.com/apikey
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=

# Chat + embedding models, as LiteLLM model strings (ADR 0006).
MODEL=gemini/gemini-2.5-flash
EMBED_MODEL=gemini/gemini-embedding-001
# Must match the embedding model output dimension (ADR 0007). We request 768 explicitly.
EMBED_DIM=768

# Database. Compose overrides this for the agent container to point at the db service.
DATABASE_URL=postgresql+psycopg://productintel:productintel@localhost:5432/productintel

# Allowed browser origin for CORS (the web app).
CORS_ORIGINS=http://localhost:3000
